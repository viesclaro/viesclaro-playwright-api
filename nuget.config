<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="github-viesclaro" value="https://nuget.pkg.github.com/viesclaro/index.json" />
  </packageSources>
  <packageSourceCredentials>
    <github-viesclaro>
      <add key="Username" value="%GITHUB_USERNAME%" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </github-viesclaro>
  </packageSourceCredentials>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-viesclaro">
      <package pattern="ViesClaro.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
